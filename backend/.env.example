# Database connection string from Supabase
# Get this from: Supabase Dashboard → Connect → Connection string (Transaction mode)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the backend server runs on
PORT=3000

# Secret used to sign JWT auth tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=

# Comma-separated list of allowed frontend origins (for CORS)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173